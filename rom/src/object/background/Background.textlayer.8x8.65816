/**
*
*/
.include "src/object/background/Background.textlayer.8x8.h"

.ramsection "textlayer font buffer" bank 0 slot 1
textlayerFontBuffer ds $600
.ends

.section "Background.textlayer.8x8"

  METHOD init
  rep #$31

  jsr _allocateMemory

  jsr _uploadFont

  jsr core.string.reset
  jsr _stringToTilemap
  jsr abstract.Background.uploadTilemap

  lda.b this.bg
  jsr abstract.Background.makePhysical

  rts

_allocateMemory:
  php
  sep #$20
  lda #BG.LAYER.2
  sta.b this.bg

  lda.b #PALETTE.BPP.2
  sta animation.tiles.bpp

  rep #$31
  lda.w #ExcFontTiles.LEN
  sta animation.tiles.length
  lda.w #_textlayerFontPal.end - _textlayerFontPal
  sta animation.palette.length
  lda.w #TILEMAP.SIZE.SINGLE
  sta animation.tilemap.length
  sta animation.frame.tilemap.length

  jsr abstract.Background.allocateMemory

  ;force palette 7 (CGRAM $38): BG3 is 2BPP, so palette N = CGRAM byte N*8 (not N*32).
  ;Palette 7 at $38-$3F avoids video palettes 0-1. Text layer must be created LAST
  ;so its play DMA queues after BGs and wins.
  rep #$31
  lda #$38
  sta.b animation.palette.start
  sep #$20
  lda #$1C                       ;palette 7 = startid $1C (bits 10-12 of tilemap)
  sta.b animation.palette.startid

  plp
  rts

_uploadFont:
  php
  rep #$31

  ;DMA font tiles directly from ROM — no transform, background stays transparent
  ;text pixels = color 1 (foreground), empty pixels = color 0 (transparent)
  sep #$20
  tsx
  lda #DMA_TRANSFER.VRAM
  pha
  pea ExcFontTiles
  lda.b #:ExcFontTiles
  pha
  rep #$31

  pei (animation.tiles.start)
  pea ExcFontTiles.LEN

  jsr core.dma.registerTransfer

  ;DMA font palette to CGRAM
  sep #$20
  lda #DMA_TRANSFER.CGRAM
  pha

  pea _textlayerFontPal
  lda.b #:_textlayerFontPal
  pha
  rep #$31

  pei (animation.palette.start)
  pea _textlayerFontPal.end - _textlayerFontPal

  jsr core.dma.registerTransfer

  txs
  plp
  rts

_textlayerFontPal:
  .dw $0000   ;color 0: transparent (unused after transform)
  .dw $7FFF   ;color 1: bright white text
  .dw $0000   ;color 2: black background (opaque)
  .dw $0000   ;color 3: unused
_textlayerFontPal.end:

_stringToTilemap:
  php
  rep #$31

  ;precompute tilemap format bits: palette + priority
  sep #$20
  lda.b animation.palette.startid
  rep #$31
  and.w #$00FF
  xba                            ;shift palette bits to high byte
  ora.w #BG.FORMAT.PRIORITY      ;combine with priority bit
  pha                            ;save on stack

  ldx #0
  ldy animation.ramBuffer.start

-	lda.w GLOBAL.CORE.STRING.buffer,x
	and.w #$ff
	sec
	sbc.w #$20	;shift back, whitespace starts at char 0 instead of $20
	ora 1,s	;apply palette + priority from stack
	sta.w GLOBAL.wramBuffer.start,y
	inx
	iny
	iny
	cpx.w #GLOBAL.CORE.STRING.buffer.length
	bne -

  pla
  plp
  rts

  METHOD play
  ;re-upload font palette to CGRAM $38 every frame. Text layer must be in the highest
  ;OopStack slot (created last) so its DMA queues after any BG palette DMA and wins.
  php
  sep #$20
  tsx
  lda #DMA_TRANSFER.CGRAM
  pha
  pea _textlayerFontPal
  lda.b #:_textlayerFontPal
  pha
  rep #$31
  pei (animation.palette.start)
  pea _textlayerFontPal.end - _textlayerFontPal
  jsr core.dma.registerTransfer
  txs
  plp
  rts

  METHOD kill
  rep #$31
  jsr abstract.Background.deallocate
  lda #OBJR_kill
  sta 3,s	
  rts

  METHOD clear
  rep #$31
  jsr core.string.reset
  rts

  METHOD print
  rep #$31
  jsr core.string.parse_from_object
  rts

  METHOD flush
  rep #$31
  jsr _stringToTilemap
  jsr abstract.Background.uploadTilemap
  rts

  CLASS Background.textlayer.8x8 clear print flush
.ends	
	
